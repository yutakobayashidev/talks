            #text(size: 14pt, fill: rgb("#757575"))[#detail]
          ]

          #grid(
            columns: (1fr, 1fr),
            column-gutter: 8mm,
            [
              #text(
                weight: "bold",
                size: 18pt,
                fill: rgb("#43A047"),
              )[観測できたこと]
              #v(2mm)
              #vis-item(
                rgb("#43A047"),
                [遮断の事実と時期],
                [Cloudflare Radar: トラフィックが0になるタイムスタンプ],
              )
              #vis-item(
                rgb("#43A047"),
                [遮断の規模],
                [全国規模 vs 局所的 / ISP別の影響],
              )
              #vis-item(
                rgb("#43A047"),
                [遮断対象サービス],
                [OONI: DNS / HTTP / IP 別の遮断手法],
              )
              #vis-item(
                rgb("#43A047"),
                [回避ツール使用急増],
                [Psiphon Conduit: 2,600万接続試行],
              )
              #vis-item(
